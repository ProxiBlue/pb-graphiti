# Copy to .env in this directory and fill in keys. .env is gitignored.

# --- Neo4j ---
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme         # change before first start
NEO4J_DATABASE=neo4j

# --- LLM (Anthropic Claude Haiku — cheap entity extraction) ---
ANTHROPIC_API_KEY=
MODEL_NAME=claude-haiku-4-5

# --- Embedder (Voyage AI — generous free tier) ---
VOYAGE_API_KEY=
EMBEDDER_MODEL=voyage-3-lite

# --- OpenAI (DUMMY — only for cross-encoder constructor) ---
# graphiti-core hardcodes OpenAIRerankerClient() as default cross_encoder; the MCP
# server does not let us swap it. Constructor needs *any* non-empty key string to
# instantiate. The reranker is only CALLED on certain search modes — if Anthropic
# Haiku covers the LLM and Voyage covers embeddings, this dummy key keeps boot
# clean. Replace with a real OpenAI key only if you hit rerank-path failures.
OPENAI_API_KEY=sk-dummy-not-used-graphiti-reranker-shim

# --- Concurrency (set to your LLM provider's tier) ---
SEMAPHORE_LIMIT=5

# --- Default group_id when caller does not supply one ---
# Should rarely fire — every Claude Code session must pass an explicit group_id.
GRAPHITI_GROUP_ID=default

USER_ID=claude
