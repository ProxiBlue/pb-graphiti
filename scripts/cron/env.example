# Copy to wherever PB_GRAPHITI_ENV points and fill in the values.
# This file is sourced by the cron wrappers — NEVER commit a populated version.
#
# Where to put this file:
#
#   Host (Linux / macOS):  $HOME/.pb-graphiti/env
#   DDEV web container:    /var/www/html/.pb-graphiti/env  ← project mount, not $HOME
#                          ($HOME inside DDEV is an overlay filesystem and is
#                          WIPED on `ddev restart`. Putting the env file under
#                          $HOME guarantees silent cron failures after the next
#                          restart. The project docroot survives because it's
#                          a host bind-mount.)
#
# Add the path to your .gitignore if it lives inside a tracked project:
#   /.pb-graphiti/env       # in DDEV / docker setups
#
# chmod 600 it so other users on the host can't read your secrets.

# === MCP target — only override if Graphiti isn't at localhost:8765 ===
# If you run the cron wrappers INSIDE a container (DDEV web service etc),
# this is host.docker.internal instead of localhost.
# GRAPHITI_URL=http://localhost:8765/mcp

# === Group id override — leave unset to derive from DDEV_PROJECT or git ===
# PB_GRAPHITI_GROUP_ID=my-project

# === Tickets ingest ===
# GitHub repo defaults to `gh repo view` from the wrapper's cwd. Override if
# the cron runs outside the repo or you want a specific one.
# PB_REPO=ITToolsAU/LaptopLCDScreen
# How many days back to fetch on each run (cron is frequent; small is fine,
# dedupe handles overlap).
# LOOKBACK_DAYS=2

# `gh` CLI auth. Personal access token or a fine-grained one with
# `repo` (read) scope. Required for tickets ingest.
export GH_TOKEN=ghp_REPLACE_ME

# === Email ingest ===
# IMAP host/port/user/folder. PASSWORD is the actual app password —
# never commit this file populated.
export IMAP_HOST=imap.example.com
export IMAP_PORT=993
export IMAP_USER=me@example.com
export IMAP_FOLDER=INBOX
export IMAP_PASSWORD=REPLACE_ME_app_password

# Relevance gates — at least one of these MUST be set or the wrapper refuses
# to run. The script enforces --require-relevance.
export PB_ADDRESSES='@client.com,external-consultant@vendor.com'
# export PB_KEYWORDS='projectname,ticket-prefix'

# Batching — defaults work for most. Tighten --batch-days for very dense
# mailboxes (Zoho closes the socket at ~2-3k messages per session).
# PB_BATCH_DAYS=7
# PB_PARALLEL=2

# === Anthropic + Voyage (used by Graphiti server, not the cron itself) ===
# These belong in your Graphiti server's .env, not here. Included for
# completeness in case a future cron wrapper needs direct LLM access.
# export ANTHROPIC_API_KEY=
# export VOYAGE_API_KEY=
